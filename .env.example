# ---------------------------------------------------------------------------
# UK Job Market Intelligence Engine — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ---------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://jobuser:password@localhost:5432/jobmarket

# PostgreSQL password (used by docker-compose for the postgres service)
POSTGRES_PASSWORD=password

# Reed.co.uk API key (username in HTTP Basic Auth; password is empty)
REED_API_KEY=your_reed_api_key_here

# Adzuna API credentials
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_API_KEY=your_adzuna_api_key_here

# pgAdmin 4 login (used only locally — change to something secure)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# Streamlit dashboard — URL of the FastAPI backend
# Change to http://api:8000 when running inside Docker
API_BASE_URL=http://localhost:8000

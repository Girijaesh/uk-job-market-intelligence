# ---------------------------------------------------------------------------
# UK Job Market Intelligence Engine — .gitignore
# ---------------------------------------------------------------------------

# Secrets — NEVER commit these
.env
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Virtual environments
venv/
.venv/
env/
ENV/

# IDEs & editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Data exports
data/*.csv
data/*.parquet
data/*.json
data/*.db

# spaCy models downloaded locally (re-downloaded in Docker/CI)
en_core_web_sm/

# Docker
*.override.yml

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
desktop.ini
